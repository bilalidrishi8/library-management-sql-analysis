-- 14. Find books that have never been issued.
-- Business Objective: Identify underutilized books.

SELECT
    b.book_title,
    b.author
FROM books b
LEFT JOIN issued_status i
ON b.isbn = i.issued_book_isbn
WHERE i.issued_id IS NULL;

-- 15. Find members who have never borrowed a book.
-- Business Objective: Identify inactive members.

SELECT
    m.member_name
FROM members m
LEFT JOIN issued_status i
ON m.member_id = i.issued_member_id
WHERE i.issued_id IS NULL;
-- 16. Calculate total rental revenue by category.
-- Business Objective: Measure revenue generated by each book category.

SELECT
    b.category,
    SUM(b.rental_price) AS total_revenue
FROM books b
JOIN issued_status i
ON b.isbn = i.issued_book_isbn
GROUP BY b.category
ORDER BY total_revenue DESC;
-- 17. Find the branch with the highest number of issued books.
-- Business Objective: Identify the busiest library branch.

SELECT
    br.branch_id,
    COUNT(i.issued_id) AS total_books_issued
FROM branch br
JOIN employees e
ON br.branch_id = e.branch_id
JOIN issued_status i
ON e.emp_id = i.issued_emp_id
GROUP BY br.branch_id
ORDER BY total_books_issued DESC
LIMIT 1;
-- 18. Find the average rental price by publisher.
-- Business Objective: Compare publishers based on rental pricing.

SELECT
    publisher,
    ROUND(AVG(rental_price),2) AS avg_rental_price
FROM books
GROUP BY publisher
ORDER BY avg_rental_price DESC;
-- 19. Find books issued more than once.
-- Business Objective: Identify popular books.

SELECT
    b.book_title,
    COUNT(i.issued_id) AS issue_count
FROM books b
JOIN issued_status i
ON b.isbn = i.issued_book_isbn
GROUP BY b.book_title
HAVING COUNT(i.issued_id) > 1
ORDER BY issue_count DESC;

-- 20. Find the most popular author.
-- Business Objective: Determine which author's books are borrowed most frequently.

SELECT
    b.author,
    COUNT(i.issued_id) AS total_issues
FROM books b
JOIN issued_status i
ON b.isbn = i.issued_book_isbn
GROUP BY b.author
ORDER BY total_issues DESC
LIMIT 1;

-- 21. Rank members based on the number of books borrowed.
SELECT
    m.member_name,
    COUNT(i.issued_id) AS books_borrowed,
    RANK() OVER (ORDER BY COUNT(i.issued_id) DESC) AS member_rank
FROM members m
JOIN issued_status i
ON m.member_id = i.issued_member_id
GROUP BY m.member_name;
-- 22. Find the most borrowed book in each category.

SELECT *
FROM (
    SELECT
        b.category,
        b.book_title,
        COUNT(i.issued_id) AS total_issues,
        ROW_NUMBER() OVER (
            PARTITION BY b.category
            ORDER BY COUNT(i.issued_id) DESC
        ) AS rn
    FROM books b
    JOIN issued_status i
    ON b.isbn = i.issued_book_isbn
    GROUP BY b.category, b.book_title
) t
WHERE rn = 1;
-- 23. Calculate the running total of books issued by date.
SELECT
    issued_date,
    COUNT(*) AS books_issued,
    SUM(COUNT(*)) OVER (
        ORDER BY issued_date
    ) AS running_total
FROM issued_status
GROUP BY issued_date;
-- 24. Find each branch's percentage contribution to total book issues.
SELECT
    br.branch_id,
    COUNT(i.issued_id) AS total_issues,
    ROUND(
        COUNT(i.issued_id) * 100.0 /
        SUM(COUNT(i.issued_id)) OVER (),
        2
    ) AS contribution_percentage
FROM branch br
JOIN employees e
ON br.branch_id = e.branch_id
JOIN issued_status i
ON e.emp_id = i.issued_emp_id
GROUP BY br.branch_id;
-- 25. Divide members into four groups based on the number of books borrowed.
SELECT
    member_name,
    books_borrowed,
    NTILE(4) OVER (ORDER BY books_borrowed DESC) AS quartile
FROM (
    SELECT
        m.member_name,
        COUNT(i.issued_id) AS books_borrowed
    FROM members m
    JOIN issued_status i
    ON m.member_id = i.issued_member_id
    GROUP BY m.member_name
) t;
-- 26. Find employees whose issued book count is above the average.
SELECT *
FROM (
    SELECT
        e.emp_name,
        COUNT(i.issued_id) AS total_issues
    FROM employees e
    JOIN issued_status i
    ON e.emp_id = i.issued_emp_id
    GROUP BY e.emp_name
) t
WHERE total_issues > (
    SELECT AVG(issue_count)
    FROM (
        SELECT COUNT(*) AS issue_count
        FROM issued_status
        GROUP BY issued_emp_id
    ) x
);
-- 27. Find the second busiest branch using DENSE_RANK().
SELECT *
FROM (
    SELECT
        br.branch_id,
        COUNT(i.issued_id) AS total_issues,
        DENSE_RANK() OVER (
            ORDER BY COUNT(i.issued_id) DESC
        ) AS ranking
    FROM branch br
    JOIN employees e
    ON br.branch_id = e.branch_id
    JOIN issued_status i
    ON e.emp_id = i.issued_emp_id
    GROUP BY br.branch_id
) t
WHERE ranking = 2;
