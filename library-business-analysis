    book_title,
    rental_price
FROM books
WHERE rental_price >
(
    SELECT AVG(rental_price)
    FROM books
);
-- 29. Calculate the difference between the highest and lowest rental prices in each category using a CTE.

WITH category_price AS (
    SELECT
        category,
        MAX(rental_price) AS highest_price,
        MIN(rental_price) AS lowest_price
    FROM books
    GROUP BY category
)
SELECT
    category,
    highest_price,
    lowest_price,
    highest_price - lowest_price AS price_difference
FROM category_price
ORDER BY price_difference DESC;

-- 30. Create a management summary report by branch.
SELECT
    br.branch_id,
    COUNT(DISTINCT e.emp_id) AS total_employees,
    COUNT(i.issued_id) AS total_books_issued,
    ROUND(SUM(b.rental_price),2) AS total_revenue
FROM branch br
LEFT JOIN employees e
    ON br.branch_id = e.branch_id
LEFT JOIN issued_status i
    ON e.emp_id = i.issued_emp_id
LEFT JOIN books b
    ON i.issued_book_isbn = b.isbn
GROUP BY br.branch_id
ORDER BY total_revenue DESC;














